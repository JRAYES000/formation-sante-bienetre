{
  "name": "formation-sante-bienetre",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agrégateur de formations CPF — vertical Santé / Bien-être / Social (lancement pôle Beauté & bien-être). Modèle Voie B (leads captifs).",
  "scripts": {
    "ingest": "tsx src/ingest/run.ts",
    "enrich:villes": "tsx src/enrich/run-villes.ts",
    "db:stats": "tsx src/ingest/stats.ts",
    "dev": "tsx watch src/server/index.ts",
    "serve": "tsx src/server/index.ts",
    "web": "vite",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "start:prod": "npm run build && npm run start",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.64.1",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "express": "^4.21.2",
    "marked": "^15.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wouter": "^3.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.2",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
