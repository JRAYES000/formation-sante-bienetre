# Driver DB : sqlite (dev) ou mysql (prod, plus tard)
DB_DRIVER=sqlite
SQLITE_PATH=./data/formations.db

# Source de données — API Opendatasoft Caisse des Dépôts (Mon Compte Formation)
ODS_BASE=https://opendata.caissedesdepots.fr/api/explore/v2.1/catalog/datasets/moncompteformation_catalogueformation

# Domaine NSF du pôle de lancement (Beauté & bien-être)
POLE_NSF=Coiffure, esthétique et autres spécialites de services aux personnes

# Port API
PORT=3001

# URL publique (canonical + sitemap en prod). En dev : déduite de la requête.
# PUBLIC_URL=https://formation-sante-bienetre.fr

# Back-office : token d'accès (générer une chaîne aléatoire)
ADMIN_TOKEN=change-me-dev-token

# Cron de fraîcheur in-process : nb d'heures entre 2 re-ingestions (0 = désactivé)
INGEST_INTERVAL_HOURS=0

# Mesure d'audience — Google Analytics 4.
# Vide = désactivé : aucun bandeau de consentement, aucun cookie, politique de confidentialité inchangée.
# Renseigné (G-XXXXXXXXXX) = bandeau de consentement affiché ; GA4 chargé seulement après "Accepter".
# GA4_MEASUREMENT_ID=

# Email Mailjet (notif partenaire à la réception d'un lead). Si vide → log stub.
# MAILJET_API_KEY=
# MAILJET_API_SECRET=
# MAIL_FROM=no-reply@formation-sante-bienetre.fr
# MAIL_FROM_NAME=Formation Santé Bien-être

# Config MySQL (prod — non utilisée en dev)
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
