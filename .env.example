# Driver DB : sqlite (dev) ou mysql (prod, plus tard)
DB_DRIVER=sqlite
SQLITE_PATH=./data/formations.db

# Source de données — API Opendatasoft Caisse des Dépôts (Mon Compte Formation)
ODS_BASE=https://opendata.caissedesdepots.fr/api/explore/v2.1/catalog/datasets/moncompteformation_catalogueformation

# Domaine NSF du pôle de lancement (Beauté & bien-être)
POLE_NSF=Coiffure, esthétique et autres spécialites de services aux personnes

# Port API
PORT=3001

# Back-office : token d'accès (générer une chaîne aléatoire)
ADMIN_TOKEN=change-me-dev-token

# Config MySQL (prod — non utilisée en dev)
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
